<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"> <!-- Status bar'dan kaçın -->

    <!-- BAŞLIK: 'Filmler' -->
    <TextView
        android:id="@+id/filmlerBaslik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filmler"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" /> <!-- status bar çakışmasını önler -->

    <!-- PROFİL BUTONU -->
    <!-- aynı şekilde çakışmayı önler -->

    <!-- RECYCLERVIEW -->

    <ImageButton
        android:id="@+id/profilButon"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="4dp"
        android:background="@android:color/transparent"
        android:contentDescription="Profil"
        android:padding="16dp"
        android:src="@drawable/iconuser"
        app:layout_constraintBottom_toBottomOf="@id/filmlerBaslik"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/filmRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/filmlerBaslik"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
